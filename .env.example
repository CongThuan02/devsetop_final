# Mẫu env cho Firebase config.
# Copy thành .env và điền giá trị thật từ Firebase Console.
# .env đã bị .gitignore — KHÔNG commit.
#
# Lưu ý: flutter_dotenv đóng gói .env vào assets, nên các giá trị này
# sẽ xuất hiện trong APK / web bundle. Bảo mật thực sự dựa vào
# Firestore Rules + App Check, KHÔNG dựa vào việc giấu API key.

FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=
